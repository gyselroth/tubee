{
    "name": "gyselroth/tubee",
    "description": "Tubee",
    "keywords": ["import", "export", "data-management"],
    "homepage": "https://github.com/gyselroth/tubee",
    "license": "GPL-3.0",
    "authors": [
        {
            "name": "gyselroth",
            "email": "mail@gyselroth.com",
            "homepage": "http://www.gyselroth.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "Tubee\\": "src/lib",
            "Tubee\\Testsuite\\": "tests"
        }
    },
    "repositories": [
        {
            "type": "git",
            "url": "https://github.com/s-aebischer/php-mongomock"
        },
        {
            "type": "git",
            "url": "https://github.com/raffis/smb"
        },
        {
            "type": "git",
            "url": "https://github.com/gyselroth/php-task-scheduler"
        },
        {
            "type": "git",
            "url": "https://github.com/gyselroth/micro-container"
        }
    ],
    "minimum-stability": "dev",
    "require": {
        "php": ">=8.2",
        "psr/log": "^1.0.0",
        "ext-mongodb": "*",
        "ext-curl": "*",
        "ext-apcu": "*",
        "ext-json":  "*",
        "gyselroth/micro-auth": "^1.1.1",
        "gyselroth/micro-container": "dev-php82#fa4d3c1",
        "psr/http-factory": "^1.0.0",
        "psr/container": "^1.0.0",
        "mongodb/mongodb": "^2.2",
        "ulrichsg/getopt-php": "^4.0",
        "laminas/laminas-mail": "^2.25",
        "gyselroth/mongodb-php-task-scheduler": "dev-tubee-php82#a3a04dc",
        "hassankhan/config": "^3.2",
        "symfony/yaml": "~3.1",
        "monolog/monolog": "^2.0.0-beta1",
        "bramus/monolog-colored-line-formatter": "~2.0",
        "laminas/laminas-servicemanager": "^3.21",
        "icewind/smb": "dev-truncate-fix",
        "psr/cache": "^1.0",
        "dreamscapes/ldap-core": "^3.1",
        "guzzlehttp/psr7": "^1.4",
        "mindplay/middleman": "^3.0",
        "lcobucci/content-negotiation-middleware": "^3.2",
        "laminas/laminas-diactoros": "^3.8",
        "psr/http-server-middleware": "*",
        "middlewares/utils": "^4.0",
        "middlewares/trailing-slash": "^2.1",
        "middlewares/access-log": "^2.2",
        "middlewares/payload": "^3.1",
        "middlewares/negotiation": "^2.2",
        "nikic/fast-route": "^1.3",
        "middlewares/fast-route": "^2.1",
        "php-jsonpatch/php-jsonpatch": "^3.0",
        "stolt/json-merge-patch": "^1.0",
        "psr/http-message": "^1.0",
        "gyselroth/stream-iterator": "^1.0.2",
        "guzzlehttp/guzzle": "~6.0",
        "paragonie/halite": "^4",
        "vanilla/garden-schema": "^2.2",
        "cache/void-adapter": "^1.0",
        "cache/apcu-adapter": "^1.0",
        "psr/simple-cache": "^1.0",
        "helmich/mongomock": "dev-tubee-php82#9982e83",
        "laminas/laminas-filter": "^2.42",
        "league/event": "^2.2",
        "composer/package-versions-deprecated": "^1.11",
        "friendsofphp/proxy-manager-lts": "^1.0",
        "laminas/laminas-httphandlerrunner": "^2.13"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "suggest": {
        "ext-v8js": "*",
        "ext-ldap": "*",
        "ext-mysqli": "*",
        "ext-pdo": "*",
        "ext-imagick": "*",
        "ext-xml": "*",
        "ext-sqlsrv":  "*"
    },
    "require-dev": {
        "phpv8/v8js-stubs": "^1.4.1",
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpunit/phpunit": "^11.5.55",
        "phpstan/phpstan": "^2.1.47"
    }
}
