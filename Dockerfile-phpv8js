# =========================
# Stage 1: build v8js
# =========================
FROM php:8.2-fpm-bookworm AS builder

RUN apt-get update && apt-get install -y \
    git \
    build-essential \
    pkg-config \
    libglib2.0-dev \
    libicu-dev \
    libxml2-dev \
    libnode-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /opt

RUN git clone https://github.com/phpv8/v8js.git

WORKDIR /opt/v8js

RUN phpize
RUN ./configure --with-v8js=/usr
RUN make -j$(nproc)
RUN make install


# =========================
# Stage 2: runtime
# =========================
FROM php:8.2-fpm-bookworm

RUN apt-get update && apt-get install -y \
    libglib2.0-0 \
    libicu72 \
    libxml2 \
    libnode108 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /usr/local/lib/php/extensions/ /usr/local/lib/php/extensions/

RUN echo "extension=v8js.so" > /usr/local/etc/php/conf.d/v8js.ini

RUN php -m | grep v8js
